# rubot — consolidated example env.
# Copy to .env per service or split as needed. Do not commit .env.

# ─────────────────────────────────────────────────────────────────────
# Shared (all Python services)
# ─────────────────────────────────────────────────────────────────────
RUBOT_SERVICE_NAME=rubot-agent-template
RUBOT_ENVIRONMENT=dev
RUBOT_DEPLOYMENT_HASH=local

# Data auth: "bearer" (default, HMAC bearers required) or "open" (no auth on data routes)
RUBOT_DATA_AUTH=open
# Fallback tenant_id in open mode (gateway only, skips session resolution)
RUBOT_OPEN_TENANT=default

# Auth between layers
GATEWAY_API_KEY=change-me-gateway
ORCHESTRATOR_API_KEY=change-me-orchestrator
MIDDLEWARE_API_KEY=change-me-middleware

# Bearer mint secret (HMAC-SHA256). 32+ bytes random.
BEARER_SIGNING_SECRET=change-me-32-bytes-of-random-hex

# Provider API keys (whichever the agent uses)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Manager auth + PIN provisioning (rubot-middleware)
# Only active when RUBOT_DATA_AUTH=bearer — in open mode the entire
# /api/auth/* + /api/provision/* subsystem is unmounted (404).
# ─────────────────────────────────────────────────────────────────────
# HMAC key for the rubot_session manager cookie. Must be different from
# BEARER_SIGNING_SECRET so the two trust domains stay isolated.
SESSION_SIGNING_SECRET=change-me-different-from-bearer-signing-secret
# Base URL of the dashboard. Used to build confirmation + reset links.
FRONTEND_URL=http://localhost:8788
MAIL_FROM=Rubot <noreply@localhost>
MAIL_BRAND_NAME=Rubot
# Optional: set to enable Resend. Empty → confirmation/reset URLs are
# logged to the worker console (dev mode).
RESEND_API_KEY=

# Registered agent ids the dashboard can toggle per tenant. Mirrors the
# keys of rubot-orchestrator's AGENT_REGISTRY_JSON. JSON array of
# strings; empty → /api/tenant/:tenantId/agents returns [].
KNOWN_AGENTS_JSON=["template"]

# Bootstrap super-admin email. First /api/auth/register call whose
# email matches (case-insensitive) is auto-confirmed + auto-approved
# + auto-elevated. No confirmation mail is sent for that account.
# Unset/empty → the first super-admin must be flipped via D1 by hand.
SUPERADMIN_EMAIL=

# ─────────────────────────────────────────────────────────────────────
# rubot-orchestrator
# ─────────────────────────────────────────────────────────────────────
# JSON map: agent_id → URL of the specialist agent service.
AGENT_REGISTRY_JSON={"template":"http://localhost:8000"}
MIDDLEWARE_URL=http://localhost:8788
PLANNER_BASE_URL=
PLANNER_API_KEY=
PLANNER_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────────────
# rubot-agent-template (and any forked specialist)
# ─────────────────────────────────────────────────────────────────────
# URL the agent uses to fetch data from rubot-middleware.
MIDDLEWARE_BASE_URL=http://localhost:8788

# ─────────────────────────────────────────────────────────────────────
# Workers (set in wrangler.jsonc vars, not here — listed for reference)
# ─────────────────────────────────────────────────────────────────────
# ORCHESTRATOR_URL=http://localhost:8001
# CHAT_SOURCE_API_KEY=change-me
