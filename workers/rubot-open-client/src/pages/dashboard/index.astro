---
import Open from "../../layouts/Open.astro";
---

<Open title="rubot open">
  <div style="background:#111827;border:1px solid #1f2937;border-radius:12px;padding:24px;color:#9ca3af">
    <h1 style="margin:0 0 8px;color:#e5e7eb;font-size:20px">Approved</h1>
    <p style="margin:0">
      Account is active. The full open-mode global admin UI is still in
      progress — for v1 the open-mode dashboard only surfaces the
      approval gate. Source/agent management is on the roadmap.
    </p>
    <p style="margin:12px 0 0">
      If you also operate a bearer-mode deployment, sign into
      <a href="/" style="color:#38bdf8">rubot-client</a> for tenant
      admin. If you're a super-admin, head to
      <a href="/" style="color:#38bdf8">rubot-superadmin</a>.
    </p>
  </div>
</Open>
