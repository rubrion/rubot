---
/**
 * Dashboard layout — auth-gates every /dashboard/* page.
 *
 *  - In open mode: renders a "bearer mode only" banner. No data fetched.
 *  - In bearer mode without a valid session: 302 → /login.
 *  - In bearer mode with a valid session: renders the page with the
 *    resolved manager exposed via `Astro.props.manager`.
 */
import type { RubotEnv } from "../lib/middleware";
import { currentManager, isBearerMode } from "../lib/session";

interface Props {
  title?: string;
}

const { title = "rubot dashboard" } = Astro.props as Props;

const env = Astro.locals.runtime.env as unknown as RubotEnv;
const cookie = Astro.request.headers.get("Cookie");

const bearerMode = isBearerMode(env);
const manager = bearerMode ? await currentManager(env, cookie) : null;

if (bearerMode && !manager) {
  return Astro.redirect("/login");
}

const pending = bearerMode && manager !== null && !manager.approved;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: light dark;
        --bg: #0a0a0a;
        --fg: #e5e7eb;
        --muted: #9ca3af;
        --brand: #f59e0b;
        --card: #111827;
        --border: #1f2937;
      }
      body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, sans-serif;
        background: var(--bg);
        color: var(--fg);
      }
      header.topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 24px;
        border-bottom: 1px solid var(--border);
      }
      header.topbar .brand {
        font-weight: 700;
        color: var(--brand);
        font-size: 18px;
      }
      header.topbar .who {
        color: var(--muted);
        font-size: 14px;
      }
      main {
        max-width: 960px;
        margin: 0 auto;
        padding: 32px 24px;
      }
      .banner {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 24px;
        margin: 32px auto;
        max-width: 640px;
        color: var(--muted);
      }
      .banner h1 {
        margin: 0 0 8px;
        color: var(--fg);
        font-size: 20px;
      }
      a {
        color: var(--brand);
      }
    </style>
  </head>
  <body>
    {bearerMode && pending ? (
      <header class="topbar">
        <span class="brand">rubot</span>
        <span class="who">{manager?.email}</span>
      </header>
      <main>
        <div class="banner">
          <h1>Pending approval</h1>
          <p>
            Your account <strong>{manager?.email}</strong> is awaiting
            super-admin approval. You can sign out and back in to refresh,
            or close this tab and check later.
          </p>
          <p>
            Tenant administration is unavailable until an approver flips
            the <code>approved</code> flag on your account.
          </p>
          <form method="POST" action="/api/proxy/auth/logout">
            <button
              type="submit"
              style="margin-top:8px;padding:8px 14px;background:#f59e0b;color:#111827;border:0;border-radius:8px;font-weight:600;cursor:pointer"
            >
              Sign out
            </button>
          </form>
        </div>
      </main>
    ) : bearerMode ? (
      <header class="topbar">
        <span class="brand">rubot</span>
        <span class="who">{manager?.email}</span>
      </header>
      <main>
        <slot />
      </main>
    ) : (
      <main>
        <div class="banner">
          <h1>Bearer mode required</h1>
          <p>
            This dashboard administers per-tenant access (managers,
            integrations, agent toggles, PINs). It only works when
            <code>RUBOT_DATA_AUTH=bearer</code> is set on
            <code>rubot-client</code> and <code>rubot-middleware</code>.
          </p>
          <p>
            See <a href="https://github.com/rubrion/rubot">docs/env-vars.md</a>
            for the mode toggle. Open-mode deployments don't have a
            tenant-ownership concept, so this UI has nothing to manage.
          </p>
        </div>
      </main>
    )}
  </body>
</html>
